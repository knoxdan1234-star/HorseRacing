# Discord Webhook URLs
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
DISCORD_PNL_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_PNL_WEBHOOK_ID/YOUR_PNL_WEBHOOK_TOKEN

# Database (default: SQLite in data/ directory)
DATABASE_URL=sqlite:///data/horseracing.db

# Betting Configuration
INITIAL_BANKROLL=10000.0
KELLY_FRACTION=0.05

# Scraping (seconds between requests to avoid rate limiting)
SCRAPE_DELAY=3.0

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
